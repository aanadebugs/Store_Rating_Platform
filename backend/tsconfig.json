{
  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "Node16",

    "rootDir": "./src",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"]
}